# Coolify deployment configuration for secure reverse shell
# Set SHELL_TOKEN to a strong random value in production

SERVICE_NAME=secure-reverse-shell
SERVICE_TYPE=docker
SERVICE_PORT=3000

# Required: Set this to a strong random token for production
# SHELL_TOKEN=your-strong-random-token-here

# Optional: Reverse proxy configuration (nginx/caddy)
# PROXY_ENABLED=true
# PROXY_HOST=shell.yourdomain.com
# PROXY_PORT=443

# Node environment
NODE_ENV=production
